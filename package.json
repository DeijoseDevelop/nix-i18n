{
  "name": "@deijose/nix-i18n",
  "version": "1.2.0",
  "description": "Internationalization library for Nix.js built on signals and stores",
  "license": "MIT",
  "author": "Deiver Vasquez",
  "type": "module",
  "homepage": "https://github.com/DeijoseDevelop/nix-i18n",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeijoseDevelop/nix-i18n.git"
  },
  "main": "./dist/lib/nix-i18n.cjs",
  "module": "./dist/lib/nix-i18n.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/nix-i18n.js",
      "require": "./dist/lib/nix-i18n.cjs",
      "types": "./dist/lib/index.d.ts"
    },
    "./format/*": {
      "import": "./dist/lib/format/*.js",
      "require": "./dist/lib/format/*.cjs",
      "types": "./dist/lib/format/*.d.ts"
    },
    "./backends/*": {
      "import": "./dist/lib/backends/*.js",
      "require": "./dist/lib/backends/*.cjs",
      "types": "./dist/lib/backends/*.d.ts"
    },
    "./plugins/*": {
      "import": "./dist/lib/plugins/*.js",
      "require": "./dist/lib/plugins/*.cjs",
      "types": "./dist/lib/plugins/*.d.ts"
    }
  },
  "keywords": [
    "nix-js",
    "i18n",
    "internationalization",
    "localization",
    "signals",
    "reactive",
    "typescript"
  ],
  "files": [
    "dist/lib",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "nix-i18n-extract": "dist/lib/cli/extract.js",
    "nix-i18n-generate": "dist/lib/cli/generate.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "clean:lib": "rm -rf dist/lib",
    "build:lib": "vite build --config vite.lib.config.ts && tsc --project tsconfig.lib.json && terser dist/lib/nix-i18n.js -c -m -o dist/lib/nix-i18n.js && terser dist/lib/nix-i18n.cjs -c -m -o dist/lib/nix-i18n.cjs",
    "prepack": "bun run clean:lib && bun run build:lib",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "extract": "bun run src/cli/extract.ts",
    "generate": "bun run src/cli/generate.ts"
  },
  "peerDependencies": {
    "@deijose/nix-js": "^2.5.3"
  },
  "peerDependenciesMeta": {
    "@deijose/nix-js": {
      "optional": false
    }
  },
  "devDependencies": {
    "@deijose/nix-js": "^2.5.3",
    "happy-dom": "^20.8.3",
    "jsdom": "^29.1.1",
    "terser": "^5.46.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  }
}